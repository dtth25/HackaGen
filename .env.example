# AI Course Generator environment
#
# Code hiện tại dùng LangChain Google GenAI. Cách an toàn nhất là export/copy
# GOOGLE_API_KEY vào environment chạy backend hoặc env_file của Docker.

# Gemini
GOOGLE_API_KEY=your_gemini_api_key_here
# Backward-compatible aliases accepted by backend config:
# GEMINI_API_KEY=your_gemini_api_key_here
# LLM_API_KEY=your_gemini_api_key_here
LLM_MODEL=gemini-2.5-flash
# LangChain batch embeddings need a batch-compatible model resource name.
EMBEDDING_MODEL=models/embedding-001

# CORS - Frontend origins (comma-separated, no spaces)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
