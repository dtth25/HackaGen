# HackaGen environment configuration
#
# Copy this file to ".env" at the PROJECT ROOT (not inside src/backend/). The
# backend always resolves its .env by an absolute path to the project root
# (see src/backend/app/core/config.py), regardless of the cwd it's run from.

# Not read by Settings (app/core/config.py) — no code branches on these today. Kept as
# human-readable context for whoever's editing this file, not live configuration.
APP_ENV=development
DEBUG=true
APP_NAME=HackaGen
FRONTEND_URL=http://localhost:3000

# Database
DATABASE_URL=sqlite:///./data/app.db
# Future production:
# DATABASE_URL=postgresql://user:pass@host:5432/db

# Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here
# Backward-compatible aliases accepted by backend config:
# GOOGLE_API_KEY=your_gemini_api_key_here
# LLM_API_KEY=your_gemini_api_key_here

# Optional: give each Study Pack feature its own Gemini key (e.g. to spread usage across
# separate free-tier quotas). Leave blank to fall back to GEMINI_API_KEY for that feature.
# GEMINI_BOOK_API_KEY=
# GEMINI_SLIDE_API_KEY=
# GEMINI_QUIZ_API_KEY=
# GEMINI_VID_API_KEY=

# Optional automatic fallback when Gemini fails/hits quota — Gemini stays primary (free).
# Blank = no-op, behavior unchanged. OPENROUTER_MODEL/OPENROUTER_EMBEDDING_MODEL only matter
# once a key is set. Covers both content generation (LLMService._call_gemini_strict) and
# document embedding/indexing (VectorStore — separate Chroma collection, see _collection_for).
# OPENROUTER_MODEL is the same family as the Gemini primary (paid, via OpenRouter) — keeps
# fallback output style/JSON discipline consistent instead of switching voice mid-course.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small

# Model routing: each feature falls back to GEMINI_DEFAULT_MODEL when left blank —
# mirrors the GEMINI_{FEATURE}_API_KEY pattern above. Actually wired (see LLMService,
# generation.py::get_generator, document_processor.py::_generate_course_title).
# Use a currently-supported alias. Bare "gemini-2.5-flash" now 404s with "no longer
# available to new users" on newer API keys/projects — gemini-flash-latest always resolves.
GEMINI_DEFAULT_MODEL=gemini-flash-latest
GEMINI_BOOK_MODEL=
GEMINI_SLIDE_MODEL=
GEMINI_QUIZ_MODEL=
GEMINI_VIDEO_MODEL=
GEMINI_COURSE_MODEL=
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# Embedding & Rate limiting
EMBEDDING_PROVIDER=gemini
EMBEDDING_BATCH_SIZE=32
EMBEDDING_BATCH_DELAY=0
EMBEDDING_MAX_RETRIES=3
EMBEDDING_MAX_RETRY_DELAY=60
EMBEDDING_REQUESTS_PER_MINUTE=72
EMBEDDING_CACHE_DIR=cache/chunk_embeddings

# Document preprocessing tuning
DOCUMENT_CHUNK_SIZE=1800
DOCUMENT_CHUNK_OVERLAP=120
PDF_ENABLE_OCR=true
PDF_OCR_MAX_PAGES=12
PDF_OCR_DPI=120
PDF_TEXT_MIN_CHARS_PER_PAGE=50
PDF_SCAN_SAMPLE_PAGES=12

# Vector DB — the only real, wired setting here is CHROMA_PERSIST_DIR/CHROMA_COLLECTION_NAME.
# Chroma is mandatory for local/dev; if it can't initialize, /health reports
# vector_db_ready=false instead of silently falling back to a fake store.
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION_NAME=ai_course_chunks

# Everything below this line (through LOCAL_CACHE_DIR) is NOT read by Settings — no
# VECTOR_DB_PROVIDER/STORAGE_PROVIDER/JOB_QUEUE_PROVIDER/CACHE_PROVIDER field exists.
# There is no provider-abstraction layer in the repo to switch via these names: vector
# storage is the single concrete app/services/vector_store.py (Chroma only, no interface),
# file storage is plain os.path/UPLOAD_DIR calls scattered across a few services, and
# "background jobs" are just FastAPI BackgroundTasks — no queue, no S3, no Milvus/Qdrant/
# pgvector, no Redis. These are reserved names for a future provider-abstraction pass, not
# live config today.
# VECTOR_DB_PROVIDER=chroma
# MILVUS_HOST=localhost
# MILVUS_PORT=19530
# MILVUS_COLLECTION_NAME=ai_course_chunks
# QDRANT_URL=
# PGVECTOR_DATABASE_URL=
# STORAGE_PROVIDER=local
# LOCAL_UPLOAD_DIR=./data/uploads
# LOCAL_OUTPUT_DIR=./data/outputs
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# JOB_QUEUE_PROVIDER=inline
# REDIS_URL=redis://localhost:6379/0
# CACHE_PROVIDER=local
# DOCUMENT_CACHE_ENABLED=true
# LOCAL_CACHE_DIR=cache

# CORS & Proxy
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Local dev (npm run dev + uvicorn as 2 separate processes): keep this pointing at the
# backend port so the browser calls it directly, e.g. http://127.0.0.1:8000.
# Docker deploy: leave this BLANK. The browser then calls same-origin (/api/...) and
# next.config.ts's rewrites() proxies server-side to the backend container internally
# (see docker-compose.yml's BACKEND_INTERNAL_URL) — the backend never needs a public port.
# WARNING: this is BAKED INTO THE FRONTEND AT BUILD TIME (docker compose passes it as the
# NEXT_PUBLIC_API_BASE_URL build arg). A non-blank value makes the BROWSER call the backend
# directly at that URL — in Docker the backend has no host port, so anything here (e.g.
# http://127.0.0.1:8000) makes every browser request miss the backend and hit whatever is
# on the visitor's OWN port 8000. Keep BLANK unless the backend truly has a public host port.
NEXT_PUBLIC_API_BASE_URL=
# Show internal source_chunk_id values in source panels for developers only.
NEXT_PUBLIC_DEVELOPER_MODE=false

# Docker deploy only — NOT read by Settings, read directly by docker-compose.yml to
# choose which HOST port the frontend container publishes to. Change this if 3000 is
# already taken on the server (e.g. by another app behind the same reverse proxy).
# Leave unset to keep the default. The backend has no host port at all — it's only
# reachable from the frontend container over the internal `hackagen-network` Docker
# network, never from the host or the internet.
# FRONTEND_PORT=3000

# Authentication & JWT Session
JWT_SECRET=CHANGE_THIS_DEV_SECRET
JWT_EXPIRE_MINUTES=10080

# Default admin bootstrap — implemented (idempotent, runs once at startup). Leave
# CREATE_DEFAULT_ADMIN=false to skip; when true, ADMIN_EMAIL/ADMIN_PASSWORD are required
# or the app refuses to start.
CREATE_DEFAULT_ADMIN=false
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-password

# Email verification & password reset (sent via SMTP — Gmail works fine for this).
# Required to actually send email; a fresh checkout without these still boots, but
# /api/auth/register and /api/auth/forgot-password will fail loudly (502) until set.
# SMTP_PASSWORD must be a Gmail "App Password" (Google Account -> Security -> 2-Step
# Verification -> App passwords), not the account's real login password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM_ADDRESS=
EMAIL_OTP_EXPIRE_MINUTES=10
EMAIL_OTP_MAX_ATTEMPTS=5
EMAIL_OTP_RESEND_COOLDOWN_SECONDS=60

# Local-only convenience: when a real send is unconfigured OR fails, log the OTP code to
# the backend console instead of failing
# the request, so registration/reset flows stay testable without real email delivery.
# NEVER set true in production — real users would get a "success" response with nobody
# actually receiving the code.
EMAIL_DEV_FALLBACK=false
