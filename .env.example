# HackaGen environment configuration
#
# Copy this file to ".env" at the PROJECT ROOT (not inside src/backend/). The
# backend always resolves its .env by an absolute path to the project root
# (see src/backend/app/core/config.py), regardless of the cwd it's run from.
#
# Cách sử dụng preset:
# - Mode Flash (Nhanh, tiết kiệm): Copy-Item .env.flash .env -Force
# - Mode Pro (Chất lượng cao):     Copy-Item .env.pro .env -Force

APP_ENV=development
DEBUG=true
APP_NAME=HackaGen

FRONTEND_URL=http://localhost:3000

# Database
DATABASE_URL=sqlite:///./data/app.db
# Future production:
# DATABASE_URL=postgresql://user:pass@host:5432/db

# Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here
# Backward-compatible aliases accepted by backend config:
# GOOGLE_API_KEY=your_gemini_api_key_here
# LLM_API_KEY=your_gemini_api_key_here

# Optional: give each Study Pack feature its own Gemini key (e.g. to spread usage across
# separate free-tier quotas). Leave blank to fall back to GEMINI_API_KEY for that feature.
# GEMINI_BOOK_API_KEY=
# GEMINI_SLIDE_API_KEY=
# GEMINI_QUIZ_API_KEY=
# GEMINI_VID_API_KEY=

# Optional automatic fallback when Gemini fails/hits quota — Gemini stays primary (free).
# Blank = no-op, behavior unchanged. OPENROUTER_MODEL only matters once a key is set.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# Model Routing Configuration
GEMINI_FAST_MODEL=gemini-2.5-flash
GEMINI_PRO_MODEL=gemini-2.5-pro
GEMINI_DEFAULT_MODEL=gemini-2.5-flash
GEMINI_QUALITY_MODEL=gemini-2.5-flash
GEMINI_BOOK_MODEL=gemini-2.5-flash
GEMINI_SLIDE_MODEL=gemini-2.5-flash
GEMINI_VIDEO_MODEL=gemini-2.5-flash
GEMINI_COURSE_MODEL=gemini-2.5-flash
GEMINI_QUIZ_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# Legacy fallback model aliases
LLM_MODEL=gemini-2.5-flash
EMBEDDING_MODEL=models/embedding-001

# Embedding & Rate limiting
EMBEDDING_PROVIDER=gemini
EMBEDDING_BATCH_SIZE=32
EMBEDDING_BATCH_DELAY=0
EMBEDDING_MAX_RETRIES=3
EMBEDDING_MAX_RETRY_DELAY=60
EMBEDDING_REQUESTS_PER_MINUTE=72
EMBEDDING_CACHE_DIR=cache/chunk_embeddings

# Document preprocessing tuning
DOCUMENT_CHUNK_SIZE=1800
DOCUMENT_CHUNK_OVERLAP=120
PDF_ENABLE_OCR=true
PDF_OCR_MAX_PAGES=12
PDF_OCR_DPI=120
PDF_TEXT_MIN_CHARS_PER_PAGE=50
PDF_SCAN_SAMPLE_PAGES=12

# Vector DB
VECTOR_DB_PROVIDER=chroma
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION_NAME=ai_course_chunks
# Chroma is mandatory for the local/dev hackathon demo. If Chroma cannot initialize,
# /health reports vector_db_ready=false instead of silently falling back to a fake store.
# Future production vector providers are reserved and not implemented for local/dev:
# VECTOR_DB_PROVIDER=milvus|qdrant|pgvector

# Future production vector config placeholders
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION_NAME=ai_course_chunks
# QDRANT_URL=
# PGVECTOR_DATABASE_URL=

# File storage
STORAGE_PROVIDER=local
LOCAL_UPLOAD_DIR=./data/uploads
LOCAL_OUTPUT_DIR=./data/outputs
# Future object storage:
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=

# Background jobs and cache
JOB_QUEUE_PROVIDER=inline
# Future worker broker:
# REDIS_URL=redis://localhost:6379/0
CACHE_PROVIDER=local
DOCUMENT_CACHE_ENABLED=true
LOCAL_CACHE_DIR=cache

# CORS & Proxy
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
# Show internal source_chunk_id values in source panels for developers only.
NEXT_PUBLIC_DEVELOPER_MODE=false

# Authentication & JWT Session
JWT_SECRET=CHANGE_THIS_DEV_SECRET
JWT_EXPIRE_MINUTES=10080

# Default admin bootstrap — implemented (idempotent, runs once at startup). Leave
# CREATE_DEFAULT_ADMIN=false to skip; when true, ADMIN_EMAIL/ADMIN_PASSWORD are required
# or the app refuses to start.
CREATE_DEFAULT_ADMIN=false
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-password

# Email verification & password reset (sent via Resend — https://resend.com). Required to
# actually send email; a fresh checkout without these still boots, but /api/auth/register
# and /api/auth/forgot-password will fail loudly (502) until they're set. RESEND_API_KEY's
# sending domain must be verified in your Resend account, or delivery to real inboxes fails.
RESEND_API_KEY=
EMAIL_FROM_ADDRESS=HackaGen <no-reply@yourdomain.com>
EMAIL_OTP_EXPIRE_MINUTES=10
EMAIL_OTP_MAX_ATTEMPTS=5
EMAIL_OTP_RESEND_COOLDOWN_SECONDS=60

# Local-only convenience: when a real send is unconfigured OR fails (e.g. Resend sending
# domain not verified yet), log the OTP code to the backend console instead of failing
# the request, so registration/reset flows stay testable without real email delivery.
# NEVER set true in production — real users would get a "success" response with nobody
# actually receiving the code.
EMAIL_DEV_FALLBACK=false
