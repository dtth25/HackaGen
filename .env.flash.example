APP_ENV=development
DEBUG=true
APP_NAME=AI Course Generator

HOST=127.0.0.1
PORT=8000
FRONTEND_URL=http://localhost:3000

# Database & CORS
DATABASE_URL=sqlite:///./data/app.db
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

GEMINI_API_KEY=PASTE_YOUR_GEMINI_API_KEY_HERE

GEMINI_FAST_MODEL=gemini-2.5-flash
GEMINI_PRO_MODEL=gemini-2.5-flash
GEMINI_DEFAULT_MODEL=gemini-2.5-flash
GEMINI_QUALITY_MODEL=gemini-2.5-flash
GEMINI_BOOK_MODEL=gemini-2.5-flash
GEMINI_SLIDE_MODEL=gemini-2.5-flash
GEMINI_VIDEO_MODEL=gemini-2.5-flash
GEMINI_COURSE_MODEL=gemini-2.5-flash
GEMINI_QUIZ_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-1.0

EMBEDDING_PROVIDER=gemini
EMBEDDING_BATCH_SIZE=32
EMBEDDING_MAX_RETRIES=3
EMBEDDING_THROTTLE_RPM=60

# Chroma is the mandatory local/dev Vector DB provider (see CLAUDE.md).
VECTOR_DB_PROVIDER=chroma
SIMPLE_VECTOR_STORE_DIR=./data/vector_store

CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION_NAME=ai_course_chunks

MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION_NAME=ai_course_chunks

UPLOAD_DIR=./data/uploads
OUTPUT_DIR=./data/outputs
INDEX_DIR=./data/indexes
BOOK_OUTPUT_DIR=./data/outputs/books
SLIDE_OUTPUT_DIR=./data/outputs/slides
VIDEO_OUTPUT_DIR=./data/outputs/videos

PDF_MAX_PAGES=300
PDF_ENABLE_OCR=false
PDF_CHUNK_SIZE=1200
PDF_CHUNK_OVERLAP=150
DOCUMENT_CACHE_ENABLED=true

ENABLE_QUALITY_GATE=true
BOOK_QUALITY_THRESHOLD=80
SLIDE_QUALITY_THRESHOLD=85
VIDEO_QUALITY_THRESHOLD=85

VIDEO_RENDERER=simple_slides
FFMPEG_PATH=ffmpeg
ENABLE_MANIM=false

JWT_SECRET=CHANGE_THIS_DEV_SECRET
JWT_EXPIRE_MINUTES=10080
CREATE_DEFAULT_ADMIN=true
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-password
